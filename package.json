{
  "name": "vantoo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node scripts/migrate.mjs",
    "db:setup-vendor": "node scripts/setup-vendor-supabase.mjs",
    "db:setup-platform": "node scripts/setup-vendor-supabase.mjs && node platform/database/seeds/seed-catalog.mjs",
    "platform:migrate": "node platform/scripts/migrate.mjs",
    "platform:seed": "node platform/database/seeds/seed-catalog.mjs",
    "platform:dev:auth": "npm run dev:auth --prefix platform",
    "platform:dev:catalog": "npm run dev:catalog --prefix platform",
    "platform:dev:order": "npm run dev:order --prefix platform",
    "platform:dev:notification": "npm run dev:notification --prefix platform",
    "platform:dev:vendor": "npm run dev:vendor --prefix platform",
    "platform:dev:local": "node scripts/start-platform.mjs",
    "platform:dev:all": "node scripts/start-platform.mjs",
    "platform:dev:rider": "npm run dev:rider --prefix platform",
    "platform:dev:tracking": "npm run dev:tracking --prefix platform",
    "platform:docker:up": "npm run docker:up --prefix platform",
    "platform:docker:down": "npm run docker:down --prefix platform",
    "platform:infra:up": "docker compose -f platform/docker/docker-compose.yml up -d postgres redis",
    "platform:test": "npm run test --prefix platform",
    "dev:admin": "npm run dev --prefix apps/admin-web",
    "build:platform": "npm run build --prefix platform",
    "build:all": "npm run build:platform && npm run build",
    "deploy": "firebase deploy --only apphosting:vantoo"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@react-google-maps/api": "^2.20.8",
    "@supabase/server": "^1.2.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.3.0",
    "firebase": "^12.15.0",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.453.0",
    "next": "^14.2.15",
    "pg": "^8.22.0",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/google.maps": "^3.65.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
