# Copy to .env for local development.
# On Vercel: Project Settings → Environment Variables → add each key below.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# @supabase/server — copy from Supabase dashboard Connect dialog (never commit secret key)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Legacy alias — optional if SUPABASE_SECRET_KEY is set
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — Session pooler (IPv4, recommended)
DATABASE_URL=

# Email (Resend) — required for password reset / transactional mail in production
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender, e.g. "Vantoo <noreply@yourdomain.com>"
# For Resend sandbox testing use: Vantoo <onboarding@resend.dev>
EMAIL_FROM=Vantoo <onboarding@resend.dev>
EMAIL_REPLY_TO=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Platform Services (Phase 2 — set PLATFORM_ENABLED=true to use microservices)
PLATFORM_ENABLED=false
PLATFORM_DATABASE_URL=postgresql://vantoo:vantoo_dev_password@localhost:5432/vantoo_platform
CATALOG_SERVICE_URL=http://localhost:4002
ORDER_SERVICE_URL=http://localhost:4003
NOTIFICATION_SERVICE_URL=http://localhost:4009
VENDOR_SERVICE_URL=http://localhost:4004
RIDER_SERVICE_URL=http://localhost:4005
TRACKING_SERVICE_URL=http://localhost:4010
AUTH_SERVICE_URL=http://localhost:4001
INTERNAL_SERVICE_KEY=dev_internal_key_change_in_production
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev_jwt_secret_change_in_production_min_32_chars
ADMIN_JWT_SECRET=dev_admin_jwt_secret_change_in_production_min_32_chars

# Google OAuth — configure the same Client ID/Secret in Supabase Dashboard
# Authentication → Providers → Google (required for Continue with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_TRACKING_SERVICE_URL=http://localhost:4010
NEXT_PUBLIC_TRACKING_SOCKET_URL=http://localhost:4010
