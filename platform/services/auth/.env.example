# Auth Service — Local Development
NODE_ENV=development
PORT=4001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://vantoo:vantoo_dev_password@localhost:5432/vantoo_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT (use a strong secret in production — minimum 32 characters)
JWT_SECRET=dev_jwt_secret_change_in_production_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_ISSUER=vantoo-auth
JWT_AUDIENCE=vantoo-platform

# OTP
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT=5
OTP_RATE_WINDOW_SECONDS=3600

# Security
MAX_SESSIONS_PER_USER=10
ACCOUNT_LOCKOUT_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=15

# OAuth (optional)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info
